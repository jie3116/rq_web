FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=replace-with-long-random-secret

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=rqdf_website

# For local test (python manage.py), this can stay localhost.
# In Docker production, DATABASE_URL is overridden by docker-compose.prod.yml to use host "db".
DATABASE_URL=postgresql+psycopg://postgres:replace-with-strong-password@127.0.0.1:5432/rqdf_website

DB_CREATE_ALL_ON_STARTUP=false
SEED_ON_STARTUP=false
FAIL_FAST_ON_DB_ERROR=true
TRUSTED_HOSTS=rqdf.co.id,www.rqdf.co.id

SCHOOL_SYSTEM_URL=https://app.rqdf.co.id
PPDB_SYSTEM_URL=https://ppdb.rqdf.co.id

SCHOOL_NAME=Pesantren RQDF
SCHOOL_PHONE=
SCHOOL_WHATSAPP=
SCHOOL_EMAIL=
SCHOOL_ADDRESS=
SCHOOL_MAP_EMBED_URL=

ADMIN_EMAIL=admin@rqdf.co.id
ADMIN_PASSWORD=replace-admin-password
