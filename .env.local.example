FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=replace-with-strong-secret

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=rqdf_website
DB_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:replace-with-strong-password@127.0.0.1:5432/rqdf_website

DB_CREATE_ALL_ON_STARTUP=true
SEED_ON_STARTUP=true
FAIL_FAST_ON_DB_ERROR=false

SCHOOL_SYSTEM_URL=http://127.0.0.1:5000
PPDB_SYSTEM_URL=https://ppdb.rqdf.co.id

SCHOOL_NAME=Pesantren RQDF
SCHOOL_PHONE=
SCHOOL_WHATSAPP=
SCHOOL_EMAIL=
SCHOOL_ADDRESS=
SCHOOL_MAP_EMBED_URL=

ADMIN_EMAIL=admin@rqdf.co.id
ADMIN_PASSWORD=replace-admin-password
